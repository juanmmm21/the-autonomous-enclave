# Copia este archivo a .env y ajusta los valores para tu máquina local.

ENCLAVE_REDIS_URL=redis://localhost:6379/0
ENCLAVE_QDRANT_URL=http://localhost:6333
ENCLAVE_POSTGRES_DSN=postgresql://enclave:enclave@localhost:5432/enclave
ENCLAVE_OLLAMA_URL=http://localhost:11434
ENCLAVE_OLLAMA_MODEL=llama3.2
ENCLAVE_JUDGE_OLLAMA_MODEL=phi4

ENCLAVE_TICK_INTERVAL_SECONDS=5.0
ENCLAVE_PASSIVE_TICK_COST=1.0
ENCLAVE_TICKS_PER_DAY=10
